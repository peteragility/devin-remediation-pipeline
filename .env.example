# ── Devin API ────────────────────────────────────────────────────────────────
# Service or personal API key from https://app.devin.ai/settings  (starts with apk_)
DEVIN_API_KEY=apk_xxxxxxxxxxxxxxxxxxxxxxxx
DEVIN_API_BASE=https://api.devin.ai/v1
# Hard cost ceiling per Devin session (Agent Compute Units). Keep low for the demo.
DEVIN_MAX_ACU=10
# Set true to run the whole pipeline against recorded fixtures (no credits burned;
# never writes to real GitHub).
DEVIN_SIMULATE=false
# Org Knowledge entry attached to every session (run scripts/setup_knowledge.py).
KNOWLEDGE_ID=
# Optional reusable Devin playbook id.
PLAYBOOK_ID=

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with `repo` scope (read issues, write comments/labels).
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
# Your fork, e.g. peterchan/superset
GITHUB_REPO=YOUR_GH_USER/superset
# Label that marks an issue as "remediate me with Devin".
TARGET_LABEL=devin-fix
# Shared secret for the GitHub webhook (Settings > Webhooks > Secret). Optional
# in local dev; set it in any exposed deployment so payloads are authenticated.
GITHUB_WEBHOOK_SECRET=

# ── Orchestrator ─────────────────────────────────────────────────────────────
# Seconds between reconcile passes when running the loop.
POLL_INTERVAL=20
# Max Devin sessions to have in-flight at once (concurrency / cost guard).
MAX_CONCURRENCY=5
# Path to SQLite system-of-record (shared between orchestrator + dashboard).
DB_PATH=data/pipeline.db
# Hung-session guard (seconds) and transient-error retry budget.
MAX_RUN_AGE_SECONDS=7200
MAX_ATTEMPTS=3

# ── Review + merge gate ──────────────────────────────────────────────────────
# Dispatch a second Devin to independently review each PR.
REVIEWER_ENABLED=true
# Risk-tiered auto-merge. OFF by default — the gate routes to a human, and GitHub
# branch protection is the real platform gate. When on, only low-risk, reviewer-
# approved, green, small-diff PRs merge (dependency bumps NEVER qualify).
AUTOMERGE_ENABLED=false
LOW_RISK_RULES=B113,B324,B506,E722
MAX_AUTOMERGE_FILES=5
MAX_AUTOMERGE_LINES=80

# ── Cost / ROI reporting (dashboard) ─────────────────────────────────────────
# Per-session ACU is read from the Devin console into fixtures/real_runs.json
# (the session API on this tier does not expose it). These convert to $.
ACU_USD_RATE=2.25
ENG_HOUR_USD=120

# ── Issue producer (scripts/scan_and_file.py) ────────────────────────────────
# Local path to a cloned Apache Superset checkout to scan. Optional:
# if unset, the script falls back to fixtures/findings.json.
SUPERSET_PATH=
