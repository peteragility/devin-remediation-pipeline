---
title: Autonomous Remediation Pipeline (Devin as a governed primitive)
---
flowchart LR
    subgraph SRC["EVENT SOURCE"]
        S1["Scan (Bandit + pip-audit)<br/>files devin-fix issues"]
    end

    O{{"ORCHESTRATOR<br/>polls open issues every 10s<br/>idempotent · ACU-capped"}}

    subgraph FX["DEVIN FIXER — fleet (N in parallel)"]
        direction TB
        F1["create session<br/>+ org Knowledge"]
        F2["sets up env · writes code<br/>runs tests · iterates · opens PR"]
        F1 --> F2
    end

    subgraph RV["REVIEWER DEVIN"]
        V1["independent audit<br/>structured verdict<br/>(approve / request_changes)"]
    end

    G{{"MERGE GATE<br/>approve + tests green?"}}

    subgraph OUT["OUTPUTS"]
        direction TB
        O1["auto-merge<br/>(OFF by default)"]
        O2["hold for human<br/>(branch protection)"]
    end

    K[("Devin Knowledge<br/>org conventions<br/>inherited by every session")]
    DB[("SQLite<br/>system of record")]
    DASH["Dashboard<br/>issue → session → PR<br/>time-to-PR · cost"]

    S1 -->|"new issue (devin-fix)"| O
    O -->|"one session per issue"| F1
    K -.-> F1
    K -.-> V1
    F2 -->|"PR"| V1
    V1 -->|"verdict artifact"| G
    G -->|"yes"| O1
    G -->|"no / disabled"| O2
    O --> DB
    F2 --> DB
    V1 --> DB
    G --> DB
    DB --> DASH
